<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chen.intellectualproperty.mapper.MailSendAttachmentMapper">

    <resultMap id="BaseResultMap" type="com.chen.intellectualproperty.model.entity.MailSendAttachment">
        <id column="id" property="id"/>
        <result column="mail_send_log_id" property="mailSendLogId"/>
        <result column="disclosure_attachment_id" property="disclosureAttachmentId"/>
        <result column="file_name" property="fileName"/>
        <result column="file_path" property="filePath"/>
        <result column="file_url" property="fileUrl"/>
        <result column="file_size" property="fileSize"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mail_send_attachment (
            mail_send_log_id, disclosure_attachment_id, file_name, file_path, file_url, file_size, create_time
        ) VALUES (
            #{mailSendLogId}, #{disclosureAttachmentId}, #{fileName}, #{filePath}, #{fileUrl}, #{fileSize}, NOW()
        )
    </insert>

    <select id="selectByLogId" resultMap="BaseResultMap">
        SELECT * FROM mail_send_attachment WHERE mail_send_log_id = #{mailSendLogId}
    </select>
</mapper>
