<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chen.intellectualproperty.mapper.EmployeeTypeMapper">

    <resultMap id="BaseResultMap" type="com.chen.intellectualproperty.model.entity.EmployeeType">
        <id column="id" property="id"/>
        <result column="type_code" property="typeCode"/>
        <result column="type_name" property="typeName"/>
        <result column="description" property="description"/>
        <result column="need_login" property="needLogin"/>
        <result column="is_system" property="isSystem"/>
        <result column="enabled" property="enabled"/>
        <result column="sort_no" property="sortNo"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, type_code, type_name, description, need_login, is_system, enabled, sort_no, create_time, update_time
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO employee_type (type_code, type_name, description, need_login, is_system, enabled, sort_no, create_time, update_time)
        VALUES (#{typeCode}, #{typeName}, #{description}, IFNULL(#{needLogin}, 1), IFNULL(#{isSystem}, 0),
                IFNULL(#{enabled}, 1), IFNULL(#{sortNo}, 0), NOW(), NOW())
    </insert>

    <update id="updateById">
        UPDATE employee_type
        <set>
            <if test="typeName != null">type_name = #{typeName},</if>
            <if test="description != null">description = #{description},</if>
            <if test="needLogin != null">need_login = #{needLogin},</if>
            <if test="enabled != null">enabled = #{enabled},</if>
            <if test="sortNo != null">sort_no = #{sortNo},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM employee_type WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM employee_type WHERE type_code = #{typeCode}
    </select>

    <select id="selectAllEnabled" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM employee_type
        WHERE enabled = 1 ORDER BY sort_no ASC, id ASC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM employee_type ORDER BY sort_no ASC, id ASC
    </select>

    <select id="selectByCodes" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM employee_type
        WHERE type_code IN
        <foreach collection="codes" item="c" open="(" separator="," close=")">#{c}</foreach>
        ORDER BY sort_no ASC, id ASC
    </select>
</mapper>
