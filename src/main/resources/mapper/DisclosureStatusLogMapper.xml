<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chen.intellectualproperty.mapper.DisclosureStatusLogMapper">

    <resultMap id="BaseResultMap" type="com.chen.intellectualproperty.model.entity.DisclosureStatusLog">
        <id column="id" property="id"/>
        <result column="disclosure_id" property="disclosureId"/>
        <result column="from_status" property="fromStatus"/>
        <result column="to_status" property="toStatus"/>
        <result column="operator_user_id" property="operatorUserId"/>
        <result column="operator_name" property="operatorName"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO disclosure_status_log (
            disclosure_id, from_status, to_status, operator_user_id, operator_name, remark, create_time
        ) VALUES (
            #{disclosureId}, #{fromStatus}, #{toStatus}, #{operatorUserId}, #{operatorName}, #{remark}, NOW()
        )
    </insert>

    <select id="selectByDisclosureId" resultMap="BaseResultMap">
        SELECT * FROM disclosure_status_log
        WHERE disclosure_id = #{disclosureId}
        ORDER BY id DESC
    </select>
</mapper>
